# bravo cluster (second Pi, 192.168.199.72) host .env - copy to .env on the host.
# Only the values that differ from alpha are documented here; fill in the secrets.

ROOT_DOMAIN=bravo.pkarpovich.space

# Cloudflare DNS-01 token for the *.bravo.pkarpovich.space wildcard cert
CF_API_EMAIL=
CF_API_KEY=

# Shared secret the CI webhook sends to trigger the updater
UPDATER_KEY=

# bravo-specific host paths (see .config/updater-bravo/updater.yml)
UPDATER_CONFIG_DIR=./.config/updater-bravo
UPDATER_SSH_KEY=/home/tuclaw/.ssh/id_rsa
